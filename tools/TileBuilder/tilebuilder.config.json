  // share the same prefix (e.g. CAPI before CT).
  "acronyms": [
    {
      "expanded": "Block automatique à permissivité restreinte",
      "acronym": "BAPR"
    },
    {
      "expanded": "Block automatique lumineux",
      "acronym": "BAL"
    },
    {
      "expanded": "Block manuel",
      "acronym": "BM"
    },
    {
      "expanded": "Cantonnement téléphonique assisté par informatique",
      "acronym": "CAPI"
    },
    {
      "expanded": "Cantonnement téléphonique",
      "acronym": "CT"
    },
    {
      "expanded": "European train control system",
      "acronym": "ETCS"
    },
    {
      "expanded": "Transmission voie-machine",
      "acronym": "TVM"
    }
  ]
}
